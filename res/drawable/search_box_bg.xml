<?xml version="1.0" encoding="utf-8"?>

<shape xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Background color -->
    <solid android:color="#2B2E5B"/>

    <!-- Rounded corners -->
    <corners android:radius="14dp"/>

    <!-- Optional border -->
    <stroke
        android:width="1dp"
        android:color="#3E4280"/>

    <!-- Padding inside -->
    <padding
        android:left="10dp"
        android:right="10dp"
        android:top="8dp"
        android:bottom="8dp"/>

</shape>