<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <ScrollView
        android:id="@+id/dashboardScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="ServiceArc"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"/>

                <ImageView
                    android:id="@+id/imgNotification"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_notification"
                    android:tint="@android:color/white"
                    android:layout_marginEnd="10dp"
                    android:clickable="true"
                    android:focusable="true"/>

                <ImageView
                    android:layout_width="34dp"
                    android:layout_height="34dp"
                    android:src="@drawable/ic_provider"
                    android:background="@drawable/circle_bg"/>
            </LinearLayout>

            <!-- Active Status Card (Dynamic) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardActiveStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                android:backgroundTint="#2B2E5B"
                android:visibility="gone">
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/btnCancelRequest">

                        <TextView
                            android:id="@+id/txtStatusTitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Searching for Provider..."
                            android:textColor="@android:color/white"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtStatusDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Please wait while we connect you."
                            android:textColor="#CCCCCC"
                            android:textSize="12sp"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:id="@+id/txtRequestTimer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Time remaining: 05:00"
                            android:textColor="#FFC107"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnCancelRequest"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:backgroundTint="#E91E63"
                        android:text="Cancel"
                        android:textColor="@android:color/white"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Service Completion & Rating Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCompletionStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                android:backgroundTint="#2E7D32"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Service Completed!"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtCompletionDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Your request has been fulfilled. Please rate your experience."
                        android:textColor="#E8F5E9"
                        android:textSize="13sp"
                        android:layout_marginTop="4dp"/>

                    <RatingBar
                        android:id="@+id/ratingBarCompletion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:layout_gravity="center_horizontal"
                        android:numStars="5"
                        android:stepSize="1"
                        android:progressTint="#FFC107"
                        android:secondaryProgressTint="#FFC107"
                        android:isIndicator="false"
                        android:minHeight="48dp"
                        style="?android:attr/ratingBarStyle" />

                    <EditText
                        android:id="@+id/editReview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/bg_search_card"
                        android:hint="Write a short review (optional)"
                        android:textColor="@android:color/white"
                        android:textColorHint="#AAAAAA"
                        android:padding="12dp"
                        android:textSize="14sp"
                        android:inputType="textMultiLine"
                        android:minLines="2" />

                    <Button
                        android:id="@+id/btnSubmitReview"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:backgroundTint="#FFFFFF"
                        android:text="Submit Review"
                        android:textColor="#2E7D32"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:cornerRadius="12dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome to ServiceArc"
                android:textColor="#CCCCCC"
                android:textSize="16sp"
                android:layout_marginTop="6dp"/>

            <!-- Search -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="14dp"
                android:backgroundTint="#2B2E5B">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:padding="10dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_search"
                        android:tint="#AAAAAA"/>
                    <EditText
                        android:id="@+id/editSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Search services..."
                        android:textColor="@android:color/white"
                        android:textColorHint="#AAAAAA"
                        android:background="@null"
                        android:layout_marginStart="8dp"
                        android:imeOptions="actionSearch"
                        android:inputType="text"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 24/7 Customer Service Banner -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="16dp"
                android:backgroundTint="#E91E63">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_alignParentStart="true"
                        android:layout_toStartOf="@id/btnHelp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="24/7 Customer Suport"
                            android:textColor="@android:color/white"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="We're here to help you anytime!"
                            android:textColor="#FCE4EC"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnHelp"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_button_white"
                        android:text="Help Me"
                        android:textColor="#E91E63"
                        android:textSize="12sp"
                        android:textAllCaps="false"
                        android:paddingStart="16dp"
                        android:paddingEnd="16dp" />
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <!-- Categories -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="4"
                android:layout_marginTop="20dp">
                <LinearLayout android:id="@+id/catElectrician" android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="45dp" android:layout_height="45dp" android:src="@drawable/ic_electrician"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Electrician" android:textColor="@android:color/white" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/catPlumber" android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="45dp" android:layout_height="45dp" android:src="@drawable/ic_plumber"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Plumber" android:textColor="@android:color/white" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/catAC" android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="45dp" android:layout_height="45dp" android:src="@drawable/ic_provider"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AC Service" android:textColor="@android:color/white" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/catCleaner" android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="45dp" android:layout_height="45dp" android:src="@drawable/ic_cleaning"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cleaner" android:textColor="@android:color/white" android:textSize="12sp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/catPainter" android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:gravity="center" android:orientation="vertical">
                    <ImageView android:layout_width="45dp" android:layout_height="45dp" android:src="@drawable/ic_labour"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Painter" android:textColor="@android:color/white" android:textSize="12sp"/>
                </LinearLayout>
            </GridLayout>

            <!-- Map -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="18dp">
                <fragment
                    android:id="@+id/map"
                    android:name="com.google.android.gms.maps.SupportMapFragment"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nearby Service Providers"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/providerRecycler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginTop="10dp"/>

        </LinearLayout>
    </ScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
